{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-issue-pr-enforce.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-safety-guard.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-precommit-lint-format.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-safety-guard.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-pre-commit-lint.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-post-change-review.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-tdd-enforce.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-lint-format.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-post-change-review.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-tdd-enforce.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-watch-list.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-pre-commit-gate.js"
          }
        ]
      }
    ]
  }
}
