{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/issue-pr-enforce.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-safety-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/copilot-merge-gate.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/precommit-lint-format.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-pre-commit-lint.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-review-gate.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-agent-teams-guide.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-post-change-review.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-tdd-enforce.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/lint-format.js"
          },
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-watch-list.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .dev-team/hooks/dev-team-pre-commit-gate.js"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
